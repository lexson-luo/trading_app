# ── Hedge Fund App – Environment Variables ────────────────────────────────────
# Copy to .env and source it:  source .env

# Database path (SQLite file)
export HF_DB_PATH="trading_app.db"

# JWT signing secret – change this before deploying!
export HF_JWT_SECRET="changeme-replace-with-random-256bit-key"

# Backend listen port
export HF_PORT="8080"

# Broker mode: "mock" (paper trading) | "rest" (live broker via REST API)
export HF_BROKER_MODE="mock"

# REST broker settings (only required if HF_BROKER_MODE=rest)
export HF_BROKER_URL=""
export HF_BROKER_API_KEY=""

# Risk limits
export HF_MAX_POSITION="100"
export HF_MAX_DAILY_LOSS="50000"
export HF_SERVER_HOST="192.168.50.243"
